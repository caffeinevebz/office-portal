// Prisma schema for the CA Firm Office Management Portal
// Domain: Clients, Staff, Compliance Tasks, Invoices, Documents

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// A client of the CA firm (individual or business entity).
model Client {
  id            String   @id @default(cuid())
  name          String
  type          String // Individual, Proprietorship, Partnership, LLP, Private Limited, Public Limited, HUF, Trust
  pan           String?
  gstin         String?
  // Tax Deduction & Collection Account Number — applies to every client.
  tan           String?
  // Entity-specific statutory registration numbers (shown by client type):
  aadhaar       String? // Individuals
  cin           String? // companies (Private/Public Limited)
  llpin         String? // LLPs — "LLP Registration No." (LLPIN)
  firmRegNo     String? // Partnership firms — Registrar of Firms number
  email         String?
  phone         String?
  address       String?
  contactPerson String?
  status        String   @default("Active") // Active, Inactive
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  groupId String?
  group   ClientGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)

  tasks      Task[]
  invoices   Invoice[]
  documents  Document[]
  schedules  ComplianceSchedule[]
  dscs       Dsc[]
  packets    DocPacket[]
  itrFilings ItrFiling[]
  tradeNames TradeName[]
  gstRegistrations GstRegistration[]
  expenseClaims ExpenseClaim[]
}

/// A physical/logical grouping of clients (e.g. a family or business group).
/// Each group has a short unique code assigned manually by the firm.
model ClientGroup {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique // manually assigned short code, e.g. "BHNS"
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clients Client[]
}

/// A firm / trade name a client operates under. A client (often a
/// proprietor) may run one or more concerns, each possibly with its own
/// GSTIN and address; an invoice can be billed under one of these instead
/// of the client's legal name.
model TradeName {
  id        String   @id @default(cuid())
  name      String
  gstin     String?
  pan       String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clientId String
  client   Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  invoices Invoice[]

  @@index([clientId])
}

/// A GST registration (GSTIN) held by a client. A single PAN-level entity may
/// be registered in several states — one GSTIN per state — and GSTR returns
/// are filed separately for each. This lets GST tasks and filing-register
/// entries be pinned to a specific GSTIN. (Distinct from TradeName, which is
/// about invoice billing identity.)
model GstRegistration {
  id        String   @id @default(cuid())
  gstin     String
  label     String? // friendly name, e.g. "Maharashtra HO", "Karnataka branch"
  stateCode String? // first two digits of the GSTIN, e.g. "27"
  state     String? // state name derived from the GSTIN state code
  address   String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clientId   String
  client     Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tasks      Task[]
  itrFilings ItrFiling[]

  @@index([clientId])
}

/// A pending email invitation to join the firm's team.
model Invitation {
  id         String    @id @default(cuid())
  email      String
  name       String?
  role       String    @default("Accountant")
  token      String    @unique
  status     String    @default("Pending") // Pending, Accepted, Revoked
  invitedBy  String // name of the staff member who sent it
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([email])
}

/// A user category (role). System roles ship with the app; admins may add
/// their own. A role's effective permissions come from RolePermission
/// overrides layered over the built-in defaults.
model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
}

/// An admin override of a role's permission. Absence of a row = the built-in
/// default for that (role, permission) pair (or "off" for custom roles).
model RolePermission {
  id         String  @id @default(cuid())
  role       String
  permission String
  allowed    Boolean

  @@unique([role, permission])
}

/// A member of the firm's team.
model Staff {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  role         String // Partner, Manager, Article Assistant, Accountant, Admin
  phone        String?
  active       Boolean  @default(true)
  passwordHash String? // scrypt hash "salt:hash"; null = cannot sign in
  // Optional 4-digit quick-access PIN. Locked after 5 wrong attempts until
  // the member signs in with their password again.
  pinHash        String?
  pinFailedCount Int     @default(0)
  createdAt    DateTime @default(now())

  tasks          Task[] @relation("TaskLeadAssignee")
  assignedTasks  Task[] @relation("TaskAssignees")
  tasksToApprove Task[] @relation("TaskApprover")
  schedules      ComplianceSchedule[]
  itrFilings     ItrFiling[]
  notifications  AppNotification[]
  expenseClaims  ExpenseClaim[]
}

/// An in-app notification for a team member — task assignments, expense-claim
/// decisions and the like. Surfaced in the header bell and mirrored to the
/// device via the browser Notification API.
model AppNotification {
  id        String    @id @default(cuid())
  type      String    @default("task-assigned") // task-assigned, task-approver, expense-raised, expense-decided
  title     String
  body      String?
  href      String? // in-app destination, e.g. /tasks
  readAt    DateTime?
  createdAt DateTime  @default(now())

  staffId String
  staff   Staff  @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId, readAt])
  @@index([staffId, createdAt])
}

/// A reimbursement claim raised by a team member for out-of-pocket expenses
/// (conveyance etc.) incurred during an audit / engagement. Approved by a
/// Partner/Admin, after which the expenses can be billed to the client.
model ExpenseClaim {
  id          String    @id @default(cuid())
  title       String // the assignment, e.g. "Bank audit – PNB Fort branch"
  periodFrom  DateTime? // audit-assignment period
  periodTo    DateTime?
  items       Json // [{ date?, category, description, amount }]
  totalAmount Float     @default(0) // kept in sync as the sum of items
  status      String    @default("Pending") // Pending, Approved, Rejected
  notes       String?
  // Approval / rejection stamp.
  decidedAt     DateTime?
  decidedById   String?
  decidedByName String?
  decisionNote  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  staffId  String
  staff    Staff   @relation(fields: [staffId], references: [id], onDelete: Cascade)
  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)
  taskId   String?
  task     Task?   @relation(fields: [taskId], references: [id], onDelete: SetNull)
  // The invoice raised to the client for these expenses (after approval).
  invoiceId String?
  invoice   Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([staffId])
  @@index([status])
}

/// A compliance / engagement task for a client.
model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  category    String    @default("Other") // Income Tax, TDS, GST, MCA/ROC, Audit, Registration, Other
  status      String    @default("Pending") // Pending, In Progress, Under Review, Completed
  priority    String    @default("Medium") // Low, Medium, High, Very High
  // Priority defaults to auto (derived from days left to the due date);
  // a Partner/Admin can pin it manually, which sets this flag.
  priorityManual Boolean @default(false)
  dueDate     DateTime?
  completedAt DateTime?
  // Return-filing tasks (GST/ITR/TDS…) auto-complete once the filing is recorded.
  isReturnFiling Boolean   @default(false)
  filingDate     DateTime?
  ackNumber      String?

  // Category-specific metadata (all optional; populated by the task form):
  taskType      String? // Income Tax: ITR Filing, Rectification, Grievance, PAN/TAN Application…
  financialYear String? // e.g. "2025-26"; the AY/TY label is derived from it
  periodMonth   Int? // 1-12, for monthly GST returns
  periodQuarter String? // Q1-Q4, for TDS / quarterly GST returns
  tdsForm       String? // new-act TDS statement number, e.g. "138" (= old 24Q)
  returnNature  String? // TDS return: Original / Revised
  gstReturnType String? // GSTR-1, GSTR-3B, GSTR-2B, GSTR-9, GSTR-9C
  gstPeriodicity String? // Monthly / Quarterly (for periodic GST returns)
  // The GSTIN this GST task is for — a client with several registrations
  // files each return separately, so each GSTIN gets its own task.
  gstin         String? // denormalised GSTIN string (shown on the task)
  checklist     Json? // [{ label, done }] — e.g. TDS certificate downloaded

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  clientId   String?
  client     Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)
  // The client GST registration this task is filed under (GST tasks only).
  gstRegistrationId String?
  gstRegistration   GstRegistration? @relation(fields: [gstRegistrationId], references: [id], onDelete: SetNull)
  // Lead assignee (kept for reminders / calendar); also present in `assignees`.
  assigneeId String?
  assignee   Staff?  @relation("TaskLeadAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  // The full set of team members a task is assigned to.
  assignees  Staff[] @relation("TaskAssignees")

  // Approval hierarchy: the Partner/Admin who signs off the finished task.
  approverId    String?
  approver      Staff?    @relation("TaskApprover", fields: [approverId], references: [id], onDelete: SetNull)
  approvedAt    DateTime?
  approvedById  String? // id of the user who approved (denormalized, no relation)
  approvedByName String? // name of the approver, for display

  // Set when a task was generated from a recurring compliance schedule.
  scheduleId String?
  schedule   ComplianceSchedule? @relation(fields: [scheduleId], references: [id], onDelete: SetNull)
  periodKey  String? // e.g. "2026-07"; unique per schedule occurrence for idempotent generation

  // Invoice lines that bill this task (to show whether it has been billed).
  invoiceLines InvoiceLineItem[]
  // Filing-register entry created when this task's filing is recorded.
  filingRecord ItrFiling?
  // Reimbursement claims raised against this engagement.
  expenseClaims ExpenseClaim[]

  @@unique([scheduleId, periodKey])
}

/// Firm-wide outbound-email configuration (single row, id = "default").
/// The official firm mailbox used as the From address for invoices,
/// documents, invitations, password resets and alert emails.
model EmailSettings {
  id           String   @id @default("default")
  provider     String   @default("google") // google (Workspace/Gmail SMTP) or resend
  fromName     String? // display name, e.g. the firm's name
  fromEmail    String? // official firm email
  replyTo      String?
  // google: an App Password for the fromEmail account (2-Step Verification
  // required). resend: an API key; falls back to the RESEND_API_KEY env var.
  appPassword  String?
  resendApiKey String?
  updatedAt    DateTime @updatedAt
}

/// A pending forgot-password reset link.
model PasswordReset {
  id        String    @id @default(cuid())
  staffId   String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([staffId])
}

/// Firm-wide reminder configuration (single row, id = "default").
model ReminderSettings {
  id              String   @id @default("default")
  enabled         Boolean  @default(true)
  leadDays        Int      @default(3) // remind when a task is due within N days (and while overdue)
  notifyAssignee  Boolean  @default(true)
  notifyClient    Boolean  @default(false)
  channelEmail    Boolean  @default(true)
  channelWhatsapp Boolean  @default(false)
  notifyDscExpiry Boolean  @default(true) // include DSC expiry reminders in runs
  dscLeadDays     Int      @default(30) // remind when a DSC expires within N days
  updatedAt       DateTime @updatedAt
}

/// An inward entry in the physical-document register: a packet of original
/// papers received from a client and held by the firm.
model DocPacket {
  id             String   @id @default(cuid())
  inwardNumber   String   @unique // e.g. IN-2627-004 (FY-based sequence)
  receivedFrom   String // person who delivered the documents
  contents       String // what is inside (e.g. "Original sale deed, 3 bank statements")
  purpose        String? // engagement it relates to
  mode           String   @default("Hand Delivery") // Hand Delivery, Courier, Post, Other
  courierRef     String? // docket/tracking no. for couriered packets
  location       String? // where the packet is stored in the office
  notes          String?
  status         String   @default("In Custody") // In Custody, Returned
  receivedByName String // portal user who recorded the receipt
  receivedAt     DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  clientId  String?
  client    Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)
  movements PacketMovement[]
}

/// Outward dispatch (or re-receipt) of a document packet.
model PacketMovement {
  id            String   @id @default(cuid())
  direction     String // Out (returned/dispatched to client), In (received back)
  outwardNumber String? // e.g. OUT-2627-002; set on Out entries
  person        String // handed to / received from
  mode          String   @default("Hand Delivery")
  courierRef    String?
  note          String?
  byName        String // portal user who recorded the movement
  createdAt     DateTime @default(now())

  packetId String
  packet   DocPacket @relation(fields: [packetId], references: [id], onDelete: Cascade)
}

/// A Digital Signature Certificate held for a client's signatory.
model Dsc {
  id           String   @id @default(cuid())
  holderName   String // the person the DSC belongs to (director/partner/proprietor)
  class        String   @default("Class 3") // Class 3, Class 2 (legacy), DGFT
  authority    String   @default("eMudhra") // issuing certifying authority
  serialNumber String?
  pin          String? // DSC password / PIN needed to use the token
  email        String? // holder contact for expiry reminders (falls back to client)
  phone        String?
  issueDate    DateTime?
  expiryDate   DateTime
  status       String   @default("Active") // Active, Revoked, Surrendered ("Expired" is derived)
  custody      String   @default("With Firm") // With Firm, With Client
  location     String? // where the token is kept when with the firm
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  clientId  String?
  client    Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)
  movements DscMovement[]
}

/// In/out register entry for a DSC token's physical custody.
model DscMovement {
  id        String   @id @default(cuid())
  direction String // In (received by firm), Out (handed to client)
  note      String?
  byName    String // portal user who recorded the movement
  createdAt DateTime @default(now())

  dscId String
  dsc   Dsc    @relation(fields: [dscId], references: [id], onDelete: Cascade)
}

/// A record of a reminder that was sent (or simulated).
model NotificationLog {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  channel       String // Email, WhatsApp
  recipientType String // Staff, Client
  recipientName String
  to            String
  subject       String
  body          String
  status        String // Sent, Simulated, Failed
  taskId        String?
  dedupeKey     String   @unique
}

/// A recurring statutory obligation for a client, used to auto-generate tasks.
model ComplianceSchedule {
  id          String   @id @default(cuid())
  title       String
  category    String   @default("Other")
  frequency   String   @default("Monthly") // Monthly, Quarterly, Half-Yearly, Annually
  dueDay      Int      @default(10) // day of month the return is due (clamped to month length)
  anchorMonth Int      @default(4) // 1-12; seeds the cycle for non-monthly frequencies
  priority    String   @default("Medium")
  active      Boolean  @default(true)
  notes       String?
  // Set when the schedule came from a built-in statutory calendar sync
  // (e.g. "income-tax"); sourceKey makes re-syncs idempotent.
  source    String?
  sourceKey String? @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clientId   String?
  client     Client? @relation(fields: [clientId], references: [id], onDelete: Cascade)
  assigneeId String?
  assignee   Staff?  @relation(fields: [assigneeId], references: [id], onDelete: SetNull)

  tasks Task[]
}

/// A billing entity of the firm — many firms invoice under more than one
/// organization (partnership, LLP, consulting company…). The default one
/// also brands the portal and is used when an invoice names none.
model Organization {
  id            String   @id @default(cuid())
  name          String
  tagline       String   @default("Chartered Accountants")
  address       String? // multiline letterhead address
  phone         String?
  email         String?
  pan           String?
  gstin         String? // state code prefix drives CGST/SGST vs IGST
  sacCode       String   @default("9982")
  bankName      String?
  bankAccount   String?
  bankIfsc      String?
  bankUpi       String?
  invoiceNote   String?
  // Short initials used to build invoice / receipt numbers, e.g. "APSB".
  invoicePrefix String?
  isDefault     Boolean  @default(false)
  logo          Bytes? // small PNG/JPEG shown in the app and on PDFs
  logoMime      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  invoices Invoice[]
}

/// A billing invoice raised to a client.
model Invoice {
  id            String    @id @default(cuid())
  invoiceNumber String    @unique
  description   String?
  amount        Float     @default(0) // pre-tax professional fee
  taxRate       Float     @default(18) // GST %
  gstMode       String    @default("Auto") // Auto (by client state), Intra, Inter, None
  status        String    @default("Draft") // Draft, Sent, Paid, Overdue
  issueDate     DateTime  @default(now())
  dueDate       DateTime?
  paidDate      DateTime?
  receiptNumber String?   @unique // assigned when marked Paid, e.g. APSB/26-27/R001
  createdAt     DateTime  @default(now())

  clientId       String
  client         Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  // Bill under a client trade name instead of the legal name (optional).
  tradeNameId    String?
  tradeName      TradeName?    @relation(fields: [tradeNameId], references: [id], onDelete: SetNull)
  // Service line items; `amount` above is kept in sync as their sum.
  lineItems      InvoiceLineItem[]
  // Reimbursement claims billed through this invoice.
  expenseClaims  ExpenseClaim[]
}

/// One billed service on an invoice. An invoice can bill several services at
/// once, and each line can be mapped to the Task it settles so the firm knows
/// which engagement has been billed.
model InvoiceLineItem {
  id          String   @id @default(cuid())
  description String
  amount      Float    @default(0) // pre-tax amount for this line
  sacCode     String? // optional per-line SAC (falls back to the org's SAC)
  createdAt   DateTime @default(now())

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  // The engagement this line bills (optional).
  taskId    String?
  task      Task?   @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([invoiceId])
  @@index([taskId])
}

/// A return-filing register entry — one filed (or in-progress) statutory
/// return per row, covering ITR, TDS, GST and MCA filings. Entries can be
/// added manually or created automatically when a return-filing task records
/// its filing. (Model name kept as ItrFiling for schema continuity.)
model ItrFiling {
  id             String    @id @default(cuid())
  returnType     String    @default("ITR") // ITR, TDS, GST, MCA
  financialYear  String? // e.g. "2025-26" (backfilled from legacy assessmentYear)
  assessmentYear String? // legacy; retained for backfill, no longer used in the UI
  formType       String    @default("ITR-1") // ITR-1…7, Form 138/24Q…, GSTR-3B…, AOC-4…
  regime         String    @default("New") // New, Old (ITR only)
  periodQuarter  String? // Q1-Q4 (TDS / quarterly GST)
  periodMonth    Int? // 1-12 (monthly GST)
  status         String    @default("Documents Awaited") // Documents Awaited, In Preparation, Filed, E-Verified, Processed, Defective
  filedOn        DateTime?
  ackNumber      String? // filing acknowledgement number
  refundAmount   Float? // expected/claimed refund, if any
  // The GSTIN a GST return was filed under (distinguishes a client's several
  // registrations in the register).
  gstin          String?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  clientId   String
  client     Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  assigneeId String?
  assignee   Staff?  @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  gstRegistrationId String?
  gstRegistration   GstRegistration? @relation(fields: [gstRegistrationId], references: [id], onDelete: SetNull)
  // The task whose "Record filing" created/updates this entry (if any).
  taskId String? @unique
  task   Task?   @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([clientId])
}

/// A document record tracked for a client.
model Document {
  id            String   @id @default(cuid())
  name          String
  category      String   @default("Other") // PAN, GST, ITR, Financial Statement, Agreement, Other
  financialYear String?
  note          String?
  uploadedAt    DateTime @default(now())

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: Cascade)
}
